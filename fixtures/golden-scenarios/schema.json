{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oppenbokforing.local/schemas/golden-scenario/v1",
  "title": "GoldenScenario",
  "description": "Machine-verifiable behavior spec for Swedish enskild firma accounting and tax paths. Not legal advice.",
  "type": "object",
  "required": ["id", "title", "profile", "transactions", "expected", "sources"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": { "type": "string", "minLength": 1 },
    "profile": {
      "type": "object",
      "required": ["ruleYear"],
      "properties": {
        "taxStatus": {
          "type": "string",
          "enum": ["f_skatt", "fa_skatt", "planning"]
        },
        "vatStatus": {
          "type": "string",
          "enum": [
            "registered",
            "exempt_low_turnover",
            "voluntary_registered"
          ]
        },
        "vatReportingPeriod": {
          "type": "string",
          "enum": ["monthly", "quarterly", "yearly"]
        },
        "expectedSalaryIncomeMinor": { "type": "integer", "minimum": 0 },
        "expectedBusinessProfitMinor": { "type": "integer", "minimum": 0 },
        "annualTurnoverMinor": { "type": "integer", "minimum": 0 },
        "accountingRegime": {
          "type": "string",
          "enum": ["k1_simplified_annual_accounts"]
        },
        "ruleYear": { "type": "integer", "minimum": 2024 }
      },
      "additionalProperties": true
    },
    "transactions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": { "type": "string", "minLength": 1 },
          "amountMinorExVat": { "type": "integer" },
          "vatRate": { "type": "number", "minimum": 0, "maximum": 1 },
          "invoiceNumber": { "type": "string" },
          "sourceInvoiceNumber": { "type": "string" },
          "fiscalYear": { "type": "integer" }
        },
        "additionalProperties": true
      }
    },
    "expected": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": true
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "format": "uri"
      }
    },
    "milestone": {
      "type": "integer",
      "minimum": 0,
      "maximum": 8,
      "description": "RFC milestone that must pass this scenario before ship"
    },
    "rfcSection": {
      "type": "string",
      "description": "RFC §9 test matrix or §7 acceptance reference"
    }
  }
}
