# ÖppenBokföring — direnv dev environment
# First time: direnv allow
#
# Provides: Node.js 22, Rust (rustc/cargo), rustfmt, clippy, sqlx-cli
# Linux also adds Tauri GTK/WebKit build deps.
# macOS still needs Xcode Command Line Tools for packaged Tauri builds.

watch_file flake.nix flake.lock
watch_file package.json src-tauri/Cargo.toml src-tauri/Cargo.lock

use flake

layout node

export OPPENBOKFORING_ROOT="$(pwd)"
export CARGO_TARGET_DIR="${OPPENBOKFORING_ROOT}/src-tauri/target"

# Local overrides (secrets, machine-specific paths) — not committed
dotenv_if_exists .env
source_env_if_exists .envrc.local
