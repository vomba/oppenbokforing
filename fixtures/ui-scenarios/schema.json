{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oppenbokforing.local/schemas/ui-scenario/v1",
  "title": "UiScenario",
  "description": "Machine-verifiable UX behavior spec for guided flows. Complements domain golden scenarios.",
  "type": "object",
  "required": ["id", "title", "milestone", "specRef", "expected", "sources"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": { "type": "string", "minLength": 1 },
    "milestone": {
      "type": "integer",
      "minimum": 1,
      "maximum": 8
    },
    "specRef": { "type": "string", "minLength": 1 },
    "rfcSection": { "type": "string" },
    "expected": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": true
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "format": "uri"
      }
    }
  }
}
